<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Job Posting</title>
</head>
<body>
    <h1>Create Job Posting</h1>
    <a href="/dashboard">Dashboard</a>

    <% if (errors && errors.length > 0) { %>
        <p><%= errors[0] %></p>
    <% } %>

    <form action="/jobs/create" method="POST">
        <label for="title">Job title</label>
        <input id="title" name="title" maxlength="45" value="<%= formData.title || '' %>" required>

        <label for="description">Description</label>
        <textarea id="description" name="description" maxlength="1000" required><%= formData.description || '' %></textarea>

        <label for="category">Category</label>
        <input id="category" name="category" maxlength="45" value="<%= formData.category || '' %>" required>

        <label for="cash">Payment ($)</label>
        <input id="cash" name="cash" type="number" min="1" step="1" value="<%= formData.cash || '' %>" required>

        <label for="image">Image filename</label>
        <input id="image" name="image" maxlength="1000" value="<%= formData.image || '' %>" required>

        <label for="status">Status</label>
        <select id="status" name="status" required>
            <option value="open" <%= formData.status !== 'closed' ? 'selected' : '' %>>Open</option>
            <option value="closed" <%= formData.status === 'closed' ? 'selected' : '' %>>Closed</option>
        </select>

        <button type="submit">Create Job</button>
    </form>
</body>
</html>

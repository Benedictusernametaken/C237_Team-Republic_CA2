<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { pageTitle: 'Gig Details' }) %>
</head>
<body>

<%- include('partials/navbar', { user: user, activePage: 'home' }) %>

<main class="container page-shell">
    <% if (messages && messages.length > 0) { %>
        <div class="alert alert-success">
            <% messages.forEach(message => { %>
                <p class="mb-0"><%= message %></p>
            <% }) %>
        </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
        <div class="alert alert-danger">
            <% errors.forEach(error => { %>
                <p class="mb-0"><%= error %></p>
            <% }) %>
        </div>
    <% } %>

    <div class="page-heading">
        <span class="auth-eyebrow">Gig information</span>
        <h1>Gig Details</h1>
        <p>Review the full information before taking action.</p>
    </div>

    <div class="card detail-card">
        <% if (gig.image) { %>
            <img
                src="/images/<%= gig.image %>"
                class="card-img-top"
                alt="<%= gig.title %>"
                style="height: 350px;"
            >
        <% } %>

        <div class="card-body">
            <h2><%= gig.title %></h2>

            <div class="detail-meta">
                <span class="meta-pill"><%= gig.category %></span>
                <span class="gig-status"><%= gig.status %></span>
                <span class="meta-pill">$<%= gig.cash %></span>
            </div>

            <hr>

            <p>
                <strong class="text-white">Description:</strong><br>
                <%= gig.description %>
            </p>

            <div class="mt-4 d-flex flex-wrap gap-2">
                <% if (gig.status === 'open' && !gig.accepted_by) { %>
                    <form action="/gig/<%= gig.gig_id %>/accept" method="POST">
                        <button type="submit" class="btn btn-primary">
                            Accept Gig
                        </button>
                    </form>
                <% } else { %>
                    <button type="button" class="btn btn-secondary" disabled>
                        Gig Unavailable
                    </button>
                <% } %>

                <a href="/report/<%= gig.gig_id %>" class="btn btn-danger">
                    Report Gig
                </a>

                <a href="/home" class="btn btn-secondary">
                    Back to Home
                </a>
            </div>
        </div>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
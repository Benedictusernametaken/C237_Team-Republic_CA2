<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Gig</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <div class="container mt-5" style="max-width: 720px;">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1>Edit Gig</h1>
            <a href="/home" class="btn btn-secondary">Back to Dashboard</a>
        </div>

        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger"><%= errors[0] %></div>
        <% } %>

        <form action="/jobs/edit/<%= gig.gig_id %>" method="POST">
            <div class="mb-3">
                <label for="title" class="form-label">Title</label>
                <input id="title" name="title" class="form-control" maxlength="45" value="<%= gig.title %>" required>
            </div>
            <div class="mb-3">
                <label for="description" class="form-label">Description</label>
                <textarea id="description" name="description" class="form-control" maxlength="1000" rows="5" required><%= gig.description %></textarea>
            </div>
            <div class="mb-3">
                <label for="cash" class="form-label">Payment ($)</label>
                <input id="cash" name="cash" type="number" class="form-control" min="1" step="1" value="<%= gig.cash %>" required>
            </div>
            <div class="mb-3">
                <label for="image" class="form-label">Image filename</label>
                <input id="image" name="image" class="form-control" maxlength="1000" value="<%= gig.image %>" required>
            </div>
            <div class="mb-3">
                <label for="category" class="form-label">Category</label>
                <input id="category" name="category" class="form-control" maxlength="45" value="<%= gig.category %>" required>
            </div>
            <button type="submit" class="btn btn-primary">Save Changes</button>
        </form>
    </div>
</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { pageTitle: 'Home' }) %>
</head>
<body>

<%- include('partials/navbar', { user: user, activePage: 'home' }) %>

<main class="container page-shell">
    <% if (messages && messages.length > 0) { %>
        <div class="alert alert-success">
            <% messages.forEach(message => { %>
                <p class="mb-0"><%= message %></p>
            <% }) %>
        </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
        <div class="alert alert-danger">
            <% errors.forEach(error => { %>
                <p class="mb-0"><%= error %></p>
            <% }) %>
        </div>
    <% } %>

    <div class="page-heading">
        <div>
            <span class="section-eyebrow">Gig Marketplace</span>
            <h1>Available Gigs</h1>
            <p>Browse the available gigs and choose one to accept.</p>
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-body">
            <form action="/home" method="GET">
                <div class="row align-items-end">
                    <div class="col-md-10 mb-3 mb-md-0">
                        <label for="search">Search by title</label>
                        <input
                            type="text"
                            id="search"
                            name="search"
                            class="form-control"
                            placeholder="Enter a gig title"
                            value="<%= search || '' %>"
                        >
                    </div>

                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">
                            Search
                        </button>
                    </div>
                </div>
            </form>
        </div>
    </div>

    <% if (gigs && gigs.length > 0) { %>
        <div class="row">
            <% gigs.forEach(gig => { %>
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <% if (gig.image) { %>
                            <img
                                src="/images/<%= gig.image %>"
                                class="card-img-top"
                                alt="<%= gig.title %>"
                                style="height: 250px; object-fit: cover;"
                            >
                        <% } %>

                        <div class="card-body">
                            <h5 class="card-title">
                                <%= gig.title %>
                            </h5>

                            <p class="card-text">
                                <strong>Category:</strong>
                                <%= gig.category %>
                            </p>

                            <p class="card-text">
                                <strong>Payment:</strong>
                                $<%= gig.cash %>
                            </p>

                            <a
                                href="/gig/<%= gig.gig_id %>"
                                class="btn btn-primary"
                            >
                                View Details
                            </a>
                        </div>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } else { %>
        <div class="empty-message">
            <p class="mb-0">No gigs found.</p>
        </div>
    <% } %>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
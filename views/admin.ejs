<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>

    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

<div class="container mt-5">

    <h1>Admin Dashboard</h1>

    <p>
        Welcome,
        <%= user.username %>
        (<%= user.role %>)
    </p>

    <hr>

    <h3>Gig Categories</h3>

    <canvas id="categoryChart" width="500" height="500"></canvas>

    <br>

    <hr>

    <h3>Pending Reports</h3>

    <% if (reports.length === 0) { %>

        <p>No pending reports.</p>

    <% } else { %>

        <table class="table table-bordered">

            <thead>
                <tr>
                    <th>Report ID</th>
                    <th>Reason</th>
                    <th>Comment</th>
                    <th>Gig ID</th>
                    <th>User ID</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>

            <tbody>

                <% reports.forEach(report => { %>

                    <tr>

                        <td>
                            <%= report.report_id %>
                        </td>

                        <td>
                            <%= report.reason %>
                        </td>

                        <td>
                            <%= report.comment %>
                        </td>

                        <td>
                            <%= report.gig_id %>
                        </td>

                        <td>
                            <%= report.user_id %>
                        </td>

                        <td>
                            <%= report.status %>
                        </td>

                        <td>

                            <form action="/admin/reports/<%= report.report_id %>/accept" method="POST">

                                <button type="submit" class="btn btn-success">
                                    Accept
                                </button>

                            </form>

                            <br>

                            <form action="/admin/reports/<%= report.report_id %>/deny" method="POST">

                                <button type="submit" class="btn btn-danger">
                                    Deny
                                </button>

                            </form>

                        </td>

                    </tr>

                <% }) %>

            </tbody>

        </table>

    <% } %>

    <br>

    <a href="/logout" class="btn btn-primary">
        Logout
    </a>

</div>

<script>

fetch('/api/gig-category-chart')
.then(response => response.json())
.then(data => {

    const labels = data.map(item => item.category);
    const totals = data.map(item => item.total);

    new Chart(document.getElementById('categoryChart'), {

        type: 'pie',

        data: {
            labels: labels,

            datasets: [{
                data: totals
            }]
        },

        options: {
            responsive: true,

            plugins: {

                title: {
                    display: true,
                    text: 'Gig Categories'
                },

                legend: {
                    position: 'right'
                }

            }
        }

    });

});

</script>

</body>
</html>
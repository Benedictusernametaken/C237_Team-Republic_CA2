<!DOCTYPE html>
<html>
<head>
    <title>Admin Dashboard</title>
    <link href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>

<body>

<div class="container mt-5 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1>Admin Dashboard</h1>
        <a href="/logout" class="btn btn-danger">Logout</a>
    </div>

    <p class="lead">
        Welcome, <strong><%= user.username %></strong> (<%= user.role %>)
    </p>

    <hr>

    <!-- Gig Categories Chart Section -->
    <div class="card mb-5">
        <div class="card-header bg-dark text-white">
            <h4 class="mb-0">Gig Categories Overview</h4>
        </div>
        <div class="card-body d-flex justify-content-center">
            <div style="max-width: 450px; width: 100%;">
                <canvas id="categoryChart"></canvas>
            </div>
        </div>
    </div>

    <!-- User Management Section -->
    <div class="card">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0">User Management</h4>
        </div>
        <div class="card-body">

            <!-- Search and Filter Form -->
            <form action="/admin" method="GET" class="form-row mb-4">
                <div class="col-md-6 mb-2">
                    <input 
                        type="text" 
                        name="search" 
                        class="form-control" 
                        placeholder="Search by username or email..." 
                        value="<%= typeof search !== 'undefined' ? search : '' %>"
                    >
                </div>
                <div class="col-md-4 mb-2">
                    <select name="filter" class="form-control">
                        <option value="all" <%= (typeof filter !== 'undefined' && filter === 'all') ? 'selected' : '' %>>All Statuses</option>
                        <option value="active" <%= (typeof filter !== 'undefined' && filter === 'active') ? 'selected' : '' %>>Active</option>
                        <option value="banned" <%= (typeof filter !== 'undefined' && filter === 'banned') ? 'selected' : '' %>>Banned</option>
                    </select>
                </div>
                <div class="col-md-2 mb-2">
                    <button type="submit" class="btn btn-primary btn-block">Apply</button>
                </div>
            </form>

            <!-- User Table -->
            <div class="table-responsive">
                <table class="table table-bordered table-striped align-middle">
                    <thead class="thead-dark">
                        <tr>
                            <th>ID</th>
                            <th>Username</th>
                            <th>Email</th>
                            <th>Contact</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (typeof users !== 'undefined' && users.length > 0) { %>
                            <% users.forEach(u => { %>
                                <tr>
                                    <td><%= u.id %></td>
                                    <td><%= u.username %></td>
                                    <td><%= u.email %></td>
                                    <td><%= u.contact %></td>
                                    <td>
                                        <% if (u.status === 'banned') { %>
                                            <span class="badge badge-danger">Banned</span>
                                        <% } else { %>
                                            <span class="badge badge-success">Active</span>
                                        <% } %>
                                    </td>
                                    <td>
                                        <% if (u.status === 'banned') { %>
                                            <form action="/admin/ban/<%= u.id %>" method="POST" style="display:inline;">
                                                <input type="hidden" name="status" value="active">
                                                <button type="submit" class="btn btn-sm btn-success">Unban</button>
                                            </form>
                                        <% } else { %>
                                            <form action="/admin/ban/<%= u.id %>" method="POST" style="display:inline;">
                                                <input type="hidden" name="status" value="banned">
                                                <button type="submit" class="btn btn-sm btn-warning" onclick="return confirm('Are you sure you want to ban this user?')">Ban</button>
                                            </form>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="6" class="text-center text-muted">No users found.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>

</div>

<script>
fetch('/api/gig-category-chart')
.then(response => response.json())
.then(data => {

    const labels = data.map(item => item.category);
    const totals = data.map(item => item.total);

    new Chart(document.getElementById('categoryChart'), {

        type: 'pie',

        data: {
            labels: labels,

            datasets: [{
                data: totals
            }]
        },

        options: {
            responsive: true,

            plugins: {

                title: {
                    display: true,
                    text: 'Gig Categories'
                },

                legend: {
                    position: 'right'
                }

            }
        }

    });

});
</script>

</body>
</html>
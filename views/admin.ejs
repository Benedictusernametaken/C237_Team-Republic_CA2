<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { pageTitle: 'Admin Dashboard' }) %>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>

<%- include('partials/navbar', { user: user, activePage: 'admin' }) %>

<main class="container page-shell">
    <% if (messages && messages.length > 0) { %>
        <div class="alert alert-success">
            <% messages.forEach(message => { %>
                <p class="mb-0"><%= message %></p>
            <% }) %>
        </div>
    <% } %>

    <% if (errors && errors.length > 0) { %>
        <div class="alert alert-danger">
            <% errors.forEach(error => { %>
                <p class="mb-0"><%= error %></p>
            <% }) %>
        </div>
    <% } %>

    <a href="/profile" class="btn btn-secondary mb-4">Back to Profile</a>
    <div class="admin-heading">
        <h1>Admin Dashboard</h1>
        <p>
            Welcome, <strong class="text-white"> <%= user.username %> </strong>
        </p>
    </div>

    <section class="admin-stats">
        <div class="summary-card">
            <h3>Total Users</h3>
            <p class="summary-number"><%= totalUsers %></p>
            <p class="stat-note mb-0">Non-admin accounts</p>
        </div>

        <div class="summary-card">
            <h3>Average Gigs Posted Per User</h3>
            <p class="summary-number"><%= averageGigsPerUser %></p>
            <p class="stat-note mb-0">
                <%= totalGigs %> total gigs
            </p>
        </div>
    </section>

    <div class="chart-grid">
        <section class="chart-panel">
            <h2 class="h4">Gig Categories</h2>
            <p>
                Gig category Data
            </p>
            <div class="chart-wrap">
                <canvas id="categoryChart"></canvas>
            </div>
        </section>

        <section class="chart-panel">
            <h2 class="h4">User Activity</h2>
            <p>
                Non-admin users activity.
            </p>

            <div class="chart-wrap">
                <canvas id="userActivityChart"></canvas>
            </div>

            <p class="chart-note mb-0">
                Each user is counted once either as posted only,
                accepted only, both, or no activity.
            </p>
        </section>
    </div>

    <section class="user-panel">
        <h2 class="h4">User Accounts</h2>

        <p>
            View and delete registered accounts.
        </p>

        <% if (!users || users.length === 0) { %>
            <div class="empty-message">
                <p class="mb-0">
                    No user accounts found.
                </p>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>User ID</th>
                            <th>Username</th>
                            <th>Role</th>
                            <th>Action</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% users.forEach(account => { %>
                            <tr>
                                <td>
                                    <%= account.id %>
                                </td>

                                <td>
                                    <%= account.username %>
                                </td>

                                <td>
                                    <span class="role-badge">
                                        <%= account.role || 'user' %>
                                    </span>
                                </td>

                                <td>
                                    <% if (account.id == user.id) { %>
                                        <button
                                            type="button"
                                            class="btn btn-secondary btn-sm"
                                            disabled
                                        >
                                            Current Account
                                        </button>
                                    <% } else { %>
                                        <form
                                            action="/admin/users/<%= account.id %>/delete"
                                            method="POST"
                                            onsubmit="return confirm('Delete this user account?')"
                                        >
                                            <button
                                                type="submit"
                                                class="btn btn-danger btn-sm"
                                            >
                                                Delete
                                            </button>
                                        </form>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </section>

    <section class="report-panel">
        <h2 class="h4">Pending Reports</h2>

        <p>
            Review reports submitted by users.
        </p>

        <% if (!reports || reports.length === 0) { %>
            <div class="empty-message">
                <p class="mb-0">
                    No pending reports.
                </p>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Report ID</th>
                            <th>Reason</th>
                            <th>Comment</th>
                            <th>Gig ID</th>
                            <th>User ID</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        <% reports.forEach(report => { %>
                            <tr>
                                <td>
                                    <%= report.report_id %>
                                </td>

                                <td>
                                    <%= report.reason %>
                                </td>

                                <td>
                                    <%= report.comment || 'No comment' %>
                                </td>

                                <td>
                                    <a href="/gig/<%= report.gig_id %>">
                                        <%= report.gig_id %>
                                    </a>
                                </td>

                                <td>
                                    <%= report.user_id %>
                                </td>

                                <td>
                                    <span class="report-status">
                                        <%= report.status %>
                                    </span>
                                </td>

                                <td>
                                    <div class="report-actions">
                                        <form
                                            action="/admin/reports/<%= report.report_id %>/accept"
                                            method="POST"
                                        >
                                            <button
                                                type="submit"
                                                class="btn btn-success btn-sm"
                                            >
                                                Accept
                                            </button>
                                        </form>

                                        <form
                                            action="/admin/reports/<%= report.report_id %>/deny"
                                            method="POST"
                                        >
                                            <button
                                                type="submit"
                                                class="btn btn-danger btn-sm"
                                            >
                                                Deny
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </section>
</main>

<script>
    function createDoughnutChart(chartId, labels, totals, colours) {
        new Chart(document.getElementById(chartId), {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: totals,
                    backgroundColor: colours,
                    borderColor: '#22304f',
                    borderWidth: 4
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        labels: {
                            color: '#f5f7ff',
                            padding: 14
                        }
                    }
                }
            }
        });
    }

    fetch('/api/gig-category-chart')
        .then(response => response.json())
        .then(data => {
            const labels = data.map(item => {
                return item.category || 'Uncategorised';
            });

            const totals = data.map(item => {
                return item.total;
            });

            const colours = [
                '#6257ff',
                '#4ea1ff',
                '#f35482',
                '#ffad22',
                '#35c98b',
                '#9478ff'
            ];

            createDoughnutChart(
                'categoryChart',
                labels,
                totals,
                colours
            );
        })
        .catch(error => {
            console.log('Unable to load category chart:', error);
        });

    const userActivity = JSON.parse('<%- JSON.stringify(userActivity) %>');

    const activityData = [
        {
            category: 'Posted Only',
            total: userActivity.postedOnlyUsers
        },
        {
            category: 'Accepted Only',
            total: userActivity.acceptedOnlyUsers
        },
        {
            category: 'Posted and Accepted',
            total: userActivity.bothUsers
        },
        {
            category: 'No Activity',
            total: userActivity.inactiveUsers
        }
    ];

    const activityLabels = activityData.map(item => {
        return item.category;
    });

    const activityTotals = activityData.map(item => {
        return item.total;
    });

    const activityColours = [
        '#6257ff',
        '#35c98b',
        '#f35482',
        '#aeb9d5'
    ];

    createDoughnutChart(
        'userActivityChart',
        activityLabels,
        activityTotals,
        activityColours
    );
</script>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<%
    const currentUser = typeof user !== 'undefined' && user ? user : null;
    const currentPage = typeof activePage !== 'undefined' ? activePage : '';
%>

<nav class="navbar navbar-expand-lg navbar-dark site-navbar">
    <div class="container">
        <a class="navbar-brand" href="<%= currentUser ? '/home' : '/login' %>">
            <span class="brand-logo">GR</span>
            GigRunners
        </a>

        <% if (currentUser) { %>
            <button
                class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#mainNavbar"
                aria-controls="mainNavbar"
                aria-expanded="false"
                aria-label="Toggle navigation"
            >
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="mainNavbar">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a href="/home" class="nav-link <%= currentPage === 'home' ? 'active' : '' %>">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/post" class="nav-link <%= currentPage === 'post' ? 'active' : '' %>">
                            Post Gig
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/profile" class="nav-link <%= currentPage === 'profile' ? 'active' : '' %>">
                            Profile
                        </a>
                    </li>

                    <li class="nav-item">
                        <a href="/logout" class="nav-link logout-link">
                            Logout
                        </a>
                    </li>
                </ul>
            </div>
        <% } %>
    </div>
</nav>
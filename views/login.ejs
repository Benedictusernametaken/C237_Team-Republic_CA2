<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head', { pageTitle: 'Login' }) %>
</head>
<body>

<%- include('partials/navbar', { user: null, activePage: '' }) %>

<main class="container page-shell">
    <div class="auth-card">
        <span class="auth-eyebrow">Welcome</span>
        <h1 class="auth-title">Login</h1>
        <p class="mb-4">Enter your username and password. We will email you a 6-digit login code.</p>

        <% if (errors && errors.length > 0) { %>
            <div class="alert alert-danger">
                <% errors.forEach(error => { %>
                    <p class="mb-0"><%= error %></p>
                <% }) %>
            </div>
        <% } %>

        <% if (messages && messages.length > 0) { %>
            <div class="alert alert-success">
                <% messages.forEach(message => { %>
                    <p class="mb-0"><%= message %></p>
                <% }) %>
            </div>
        <% } %>

        <form action="/login" method="POST">
            <div class="mb-3">
                <label for="username">Username</label>
                <input
                    type="text"
                    id="username"
                    name="username"
                    class="form-control"
                    placeholder="Enter your username"
                    required
                >
            </div>

            <div class="mb-4">
                <label for="password">Password</label>
                <input
                    type="password"
                    id="password"
                    name="password"
                    class="form-control"
                    placeholder="Enter your password"
                    required
                >
            </div>

            <div class="auth-actions">
                <button type="submit" class="btn btn-primary">
                    Login
                </button>

                <a href="/register" class="btn btn-secondary">
                    Create Account
                </a>
            </div>
        </form>
    </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>